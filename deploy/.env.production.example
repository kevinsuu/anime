# Production environment for anime.kaistarstudio.me
# Copy to .env next to docker-compose.yml on the deploy host and fill in
# real values. Never commit the filled-in version.

# --- Image tags (set by the deploy workflow, or manually for a rollback) ---
BACKEND_IMAGE=ghcr.io/kevinsuu/anime-backend:latest
SCHEDULER_IMAGE=ghcr.io/kevinsuu/anime-scheduler:latest
FRONTEND_IMAGE=ghcr.io/kevinsuu/anime-frontend:latest
BACKUP_IMAGE=ghcr.io/kevinsuu/anime-db-backup:latest

# --- App ---
APP_NAME=AnimeTracker
APP_KEY=base64:generate-a-real-laravel-app-key
APP_URL=https://anime.kaistarstudio.me

# --- Database ---
DB_DATABASE=anime_tracker
DB_USERNAME=anime
DB_PASSWORD=replace-with-real-password
MYSQL_ROOT_PASSWORD=replace-with-real-password
BACKUP_RETENTION_DAYS=30

# --- Backend runtime ---
JWT_SECRET=replace-with-long-random-secret
JWT_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000
BANGUMI_API_BASE_URL=https://api.bgm.tv
BANGUMI_USER_AGENT=anime-tracker/1.0
HTTP_TIMEOUT_SECONDS=10

# --- CORS ---
ALLOWED_ORIGINS=https://anime.kaistarstudio.me

# --- Google OAuth ---
# Remember to add https://anime.kaistarstudio.me to the OAuth client's
# authorized JavaScript origins in Google Cloud Console.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
