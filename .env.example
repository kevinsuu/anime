# Single source of truth for local docker-compose environment.
# Copy to .env and fill in real values. All services
# (mysql/backend/scheduler/frontend/phpmyadmin) read from .env.

# --- App ---
APP_NAME=AnimeTracker
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=anime_tracker
DB_USERNAME=anime
DB_PASSWORD=replace-with-real-password
MYSQL_ROOT_PASSWORD=replace-with-real-password

# --- Backend runtime ---
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
JWT_SECRET=replace-with-long-random-secret
JWT_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000
DEV_AUTH_BYPASS=false
BANGUMI_API_BASE_URL=https://api.bgm.tv
BANGUMI_USER_AGENT=anime-tracker/1.0
HTTP_TIMEOUT_SECONDS=10

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,https://your-github-user.github.io

# --- 個人觀看清單 ---
# 設定後 anime:import-acgsecrets 會把 seed/mylist/watched.json 標記為此使用者已看過
MYLIST_OWNER_EMAIL=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# --- Frontend (Nuxt) ---
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080
NUXT_PUBLIC_ENABLE_DEV_LOGIN=false
